# ─────────────────────────────────────────
#  Database
# ─────────────────────────────────────────
POSTGRES_DB=ob_inventory
POSTGRES_USER=ob_user
POSTGRES_PASSWORD=changeme_strong_password_here

# Used by api and worker (inside Docker network: host = postgres)
DATABASE_URL=postgresql://ob_user:changeme_strong_password_here@postgres:5432/ob_inventory

# Used for local dev (host = localhost)
# DATABASE_URL=postgresql://ob_user:changeme_strong_password_here@localhost:5432/ob_inventory

# ─────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────
# Inside Docker network
REDIS_URL=redis://redis:6379

# Local dev
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_byte_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
#  WooCommerce
# ─────────────────────────────────────────
WOO_STORE_URL=https://your-woocommerce-store.com
WOO_API_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_API_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret for verifying inbound WC webhooks (set same value in WC webhook settings)
WOO_WEBHOOK_SECRET=replace_with_random_webhook_secret

# API key for the WordPress plugin to call back into this system
WOO_PLUGIN_API_KEY=replace_with_random_api_key

# ─────────────────────────────────────────
#  Server
# ─────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
WEB_PORT=8080

# ─────────────────────────────────────────
#  Caddy (production only)
# ─────────────────────────────────────────
DOMAIN=yourdomain.com
CADDY_EMAIL=admin@yourdomain.com
